# ═══════════════════════════════════════════════════════════════
# Nestandart — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ─── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here
MANAGER_CHAT_ID=your_chat_id_here

# ─── AI Fallback Chain: AITUNNEL → Groq → OpenRouter → Gemini ──
#
# Порядок вызова:
#   Каскад по умолчанию: groq → aitunnel → openrouter → gemini (код providers/ai.py)
#   2. Groq      — запасной (бесплатный, ultra-fast)
#   3. OpenRouter — третий (международный агрегатор)
#   4. Gemini    — аварийный (бесплатный, прямой API Google)

# AITUNNEL — aitunnel.ru
AITUNNEL_API_KEY=your_aitunnel_api_key_here
AITUNNEL_MODEL=gemini-2.5-flash
# Доступные модели: gemini-2.5-flash, gpt-4o-mini, deepseek-chat, claude-haiku-4.5

# 2. Groq (запасной) — console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# 3. OpenRouter (третий) — openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# 4. Gemini (аварийный) — aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── n8n (локальный) ──────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
N8N_HOST=http://localhost:5678

# ─── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8000

# ─── YooKassa (оплата) ────────────────────────────────────────
# Пустые SHOP_ID/SECRET_KEY → платежи мягко отключены (бот предложит менеджера).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://nestandart.online/
YOOKASSA_BAHT_TO_RUB=2.6   # курс ฿→₽ для расчёта суммы (правится без кода)

# ─── Monitoring ────────────────────────────────────────────────
# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=

# ─── AWS S3 (optional, for backup upload) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ─── Bot (Python, disabled) ───────────────────────────────────
# Для включения: docker compose --profile bot up -d
WEBHOOK_URL=https://nestandart.online
BOT_PORT=8081

# Секрет-гейт backend (X-Kote-Secret + p_secret в RPC). Обязателен в проде.
KOTE_RPC_SECRET=change_me_shared_secret
